{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "list": "allow",
    "bash": {
      // General
      "find *": "ask", // Find can execute code with `-exec`.
      "grep *": "allow",
      "ls *": "allow",
      "wc *": "allow",
      // Git
      "git add *": "allow",
      "git commit *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow"
    }
  },
  "model": "qwen/qwen3-coder-next",
  "small_model": "google/gemma-4-e4b",
  "provider": {
    "open-webui": {
      // Run `/connect` with "Other Custom Provider" to configure the API key, name "open-webui".
      "npm": "@ai-sdk/openai-compatible",
      "name": "Open WebUI (local)",
      "options": {
        "baseURL": "https://ai.scalzotto.nl/api"
      },
      "models": {
        "qwen/qwen3-coder-next": {
          "name": "Qwen3 Coder Next",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "qwen/qwen3.6-35b-a3b": {
          "name": "Qwen3.6",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "qwen/qwen3.6-27b": {
          "name": "Qwen3.6 Dense",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "google/gemma-4-e4b": {
          "name": "Gemma 4",
          "limit": {
            "context": 131072,
            "output": 65536
          }
        }
      }
    }
  }
}
